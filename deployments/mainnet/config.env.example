# Astrion Protocol — MAINNET configuration template
#
# ⚠  MAINNET — all transactions are irreversible and involve real value.
#
# Instructions:
#   cp deployments/mainnet/config.env.example deployments/mainnet/config.env
#   # Fill in every value below, then:
#   make deploy-all NETWORK=mainnet SOURCE=<your-key>
#   make init-all   NETWORK=mainnet SOURCE=<your-key>
#   make verify     NETWORK=mainnet
#
# Security checklist before deploying to mainnet:
#   [ ] Audit complete and all findings addressed
#   [ ] ADMIN_ADDRESS is a multisig (not a single hot key)
#   [ ] TREASURY_ADDRESS is a cold or multisig wallet
#     [ ] Oracle contract has been independently reviewed
#   [ ] Risk parameters reviewed by a financial risk analyst
#   [ ] Supply and borrow caps set (start conservative — increase later)
#   [ ] Emergency pause mechanism confirmed

# ─── Governance ───────────────────────────────────────────────────────────────
# Must be a multisig wallet. Transfer here via make rotate-admin after launch.
ADMIN_ADDRESS=

# Protocol revenue recipient. Use a cold or multisig wallet.
TREASURY_ADDRESS=

# ─── Oracle ───────────────────────────────────────────────────────────────────
# SEP-0402 / Reflector-compatible oracle contract on mainnet.
# Confirm this is the canonical, audited oracle before deploying.
DEFAULT_ORACLE_ID=

# Mainnet: tighter staleness window than testnet (120s vs 300s).
# Increase only with risk team approval.
DEFAULT_MAX_STALENESS=120

# ─── Interest Rate Model ─────────────────────────────────────────────────────
# All values are WAD-scaled (1e18 = 100%).
# These match the v1 conservative parameters from the smart contract spec.
# Do NOT change without risk team review and governance approval.
#
#   base_rate:           1%  APR at 0% utilization
#   slope1:              4%  APR slope below optimal
#   slope2:              75% APR slope above optimal (cliff to deter over-borrowing)
#   optimal_utilization: 80% utilization target
#   reserve_factor:      10% of interest goes to the protocol treasury
BASE_RATE=10000000000000000
SLOPE1=40000000000000000
SLOPE2=750000000000000000
OPTIMAL_UTILIZATION=800000000000000000
RESERVE_FACTOR=100000000000000000

# ─── Liquidation Engine ───────────────────────────────────────────────────────
# Max fraction of a position that can be closed in one liquidation (WAD).
# 50% is standard (Aave v3 default). Lower = more liquidation rounds needed.
CLOSE_FACTOR=500000000000000000

# ─── CorePool market (optional — add first market during init) ────────────────
# Uncomment and set these to add a market atomically during initialization.
# Use conservative caps for launch — expand after monitoring behaviour.
#
# CORE_MARKET_ASSET=                         # Stellar asset contract ID
# CORE_MARKET_LTV=650000000000000000         # 65% LTV (conservative mainnet start)
# CORE_MARKET_LIQUIDATION_THRESHOLD=750000000000000000   # 75%
# CORE_MARKET_LIQUIDATION_BONUS=50000000000000000        # 5% bonus to liquidators
# CORE_MARKET_RESERVE_FACTOR=100000000000000000          # 10%
# CORE_MARKET_SUPPLY_CAP=1000000000000000000000000       # Set a real cap — do not use 0 on mainnet
# CORE_MARKET_BORROW_CAP=800000000000000000000000        # Set a real cap — do not use 0 on mainnet
# CORE_MARKET_IS_ACTIVE=true
# CORE_MARKET_IS_BORROWABLE=true

# ─── Isolated Market (optional — add first isolated market during init) ───────
# MARKET_COLLATERAL_ASSET=
# MARKET_DEBT_ASSET=
# MARKET_LTV=600000000000000000             # 60% — isolated markets get tighter LTV
# MARKET_LIQUIDATION_THRESHOLD=700000000000000000
# MARKET_LIQUIDATION_BONUS=80000000000000000  # 8% — isolated markets need higher bonus
# MARKET_RESERVE_FACTOR=100000000000000000
# MARKET_SUPPLY_CAP=500000000000000000000000  # Mandatory on mainnet
# MARKET_BORROW_CAP=400000000000000000000000  # Mandatory on mainnet
