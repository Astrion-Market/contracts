# Copy to deployments/testnet/config.env and fill real addresses.

ADMIN_ADDRESS=
TREASURY_ADDRESS=

# External SEP-0402 / Reflector-compatible oracle contract.
DEFAULT_ORACLE_ID=
DEFAULT_MAX_STALENESS=300

# Interest rate model WAD parameters.
BASE_RATE=10000000000000000
SLOPE1=40000000000000000
SLOPE2=750000000000000000
OPTIMAL_UTILIZATION=800000000000000000
RESERVE_FACTOR=100000000000000000

# Liquidation engine.
CLOSE_FACTOR=500000000000000000

# Optional: add one CorePool market during init.
# CORE_MARKET_ASSET=
# CORE_MARKET_LTV=700000000000000000
# CORE_MARKET_LIQUIDATION_THRESHOLD=800000000000000000
# CORE_MARKET_LIQUIDATION_BONUS=50000000000000000
# CORE_MARKET_RESERVE_FACTOR=100000000000000000
# CORE_MARKET_SUPPLY_CAP=0
# CORE_MARKET_BORROW_CAP=0
# CORE_MARKET_IS_ACTIVE=true
# CORE_MARKET_IS_BORROWABLE=true

# Optional: initialize the standalone isolated market during init.
# MARKET_COLLATERAL_ASSET=
# MARKET_DEBT_ASSET=
# MARKET_LTV=700000000000000000
# MARKET_LIQUIDATION_THRESHOLD=800000000000000000
# MARKET_LIQUIDATION_BONUS=50000000000000000
# MARKET_RESERVE_FACTOR=100000000000000000
# MARKET_SUPPLY_CAP=0
# MARKET_BORROW_CAP=0

# Optional dev-flow values.
# SIM_TOTAL_BORROWED=80000000000000000000
# SIM_TOTAL_SUPPLIED=100000000000000000000
# SIM_ASSET=
# SIM_SUPPLY_AMOUNT=
# SIM_BORROW_AMOUNT=
